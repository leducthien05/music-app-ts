extends ../../layout/auth.pug

block content
    .auth-container
        .auth-card
            h2 Đặt lại mật khẩu
            p Nhập email của bạn để nhận link đặt lại mật khẩu

            form(
                method="POST", 
                action="/users/reset-password"
            )
                input(
                    type="email", 
                    name="email", 
                    value=email,
                    readonly 
                    required
                )
                input(
                    type="password", 
                    name="password", 
                    placeholder="Nhập mật khẩu mới...", 
                    required
                )
                input(
                    type="text", 
                    name="confirmPassword", 
                    placeholder="Xác nhận mật khẩu mới...", 
                    required    
                )
                button(class="btn") Đặt lại mật khẩu

            a.back(href="/users/login") ← Quay lại đăng nhập