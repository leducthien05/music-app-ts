extends ../../layout/auth.pug

block content
    .auth-container
        .auth-card
            h2 Quên mật khẩu
            p Nhập email của bạn để nhận link đặt lại mật khẩu

            form(
                method="POST", 
                action="/users/forgot-password"
            )
                input(
                    type="email", 
                    name="email", 
                    placeholder="Nhập email...", 
                    required
                )
                button(class="btn") Gửi yêu cầu

            a.back(href="/users/login") ← Quay lại đăng nhập