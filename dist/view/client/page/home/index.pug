extends ../../layout/default.pug
include ../../mixin/box-head.pug

block content
    .topbar
        div(class="greeting")
            | Chào buổi sáng, 
            span Bạn ơi
            |  🌤

    section
        div(class="section-title") ✦ Chủ đề

        div(class="featured-grid")
            each item in topic
                a(
                    class="topic-card"
                    href=`/topics/${item.slug}`
                )
                    img(
                        class="topic-img"
                        src=item.avatar, 
                        alt=item.title
                    )

                    div(class="topic-overlay")
                    div(class="topic-info")
                        h3 #{item.title}
                        p !{item.description}

    section
        div(class="section-title") 🎶 Bài hát phổ biến

        .search-page
            .search-wrapper
                if(songs)
                    div(class="songs-list")
                        each song, index in songs
                            div(
                                class="song-row"
                                onclick=`playSong('${song._id}')`
                            )
                                div(class="song-left")
                                    span(class="song-index") #{index + 1}
                                    img(
                                        class="song-thumb"
                                        src=song.avatar , 
                                        alt=song.nameSong
                                    )

                                    div(class="song-info")
                                        a(href=`/songs/detail/${song.slug}`)
                                            div(class="song-title") #{song.nameSong}
                                        div(class="song-artist") #{song.infoSinger.nameSinger}

                                button(
                                    class=`btn-favorite ${favorite == "1" ? "favorite" : ""}`
                                    data-song-id-favorite=song._id
                                ) 
                                    span(class="text") ♥ Yêu thích