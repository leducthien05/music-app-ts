extends ../../layout/auth.pug

block content
    .auth-wrapper
        .auth-card
            h2.auth-title Đăng nhập hệ thống

            form(
                method="POST" 
                action=`${prefixAdmin}/auth/login`
            )
                .form-group
                    label Email
                    input(
                        type="email"
                        name="email"
                        placeholder="Nhập email..."
                        required
                    )

                .form-group
                    label Mật khẩu
                    input(
                        type="password"
                        name="password"
                        placeholder="Nhập mật khẩu..."
                        required
                    )

                .form-options
                    label
                        input(type="checkbox" name="remember")
                        |  Ghi nhớ đăng nhập

                button.btn-login(type="submit") Đăng nhập