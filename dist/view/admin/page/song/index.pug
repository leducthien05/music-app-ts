extends ../../layout/default
include ../../mixin/pagination.pug
include ../../mixin/filterStatus.pug
include ../../mixin/convertTime.pug

block content
    div(class="dashboard")

        // STAT CARDS
        div(class="stats")
            div(class="card")
                p Tổng bài hát
                h2 1,248
                span(class="up") ↑ 12 bài tuần này

            div(class="card")
                p Lượt nghe hôm nay
                h2 8,462
                span(class="up") ↑ 5.2%

            div(class="card")
                p Người dùng
                h2 3,891
                span(class="up") ↑ 24

            div(class="card")
                p Yêu thích
                h2 15,703
                span(class="down") ↓ 1.1%
        div.filter-wrapper
            +filterStatus
            div.filters
                //- Select Thể loại
                select(name="topic" id="topic")
                    option(value="") Tất cả thể loại
                    each item in topic
                        option(
                            value=item.slug
                        ) #{item.title}

                //- Select Ca sĩ
                select(name="singer" id="singer")
                    option(value="") Tất cả ca sĩ
                    each item in singer
                        option(
                            value=item.slug
                        ) #{item.nameSinger}
                button(
                    btn-clear
                ) Clear

        // SEARCH
        div(class="search-bar")
            form(
                method="GET"
                form-search
                
            )
                input(
                    type="text", 
                    placeholder="Tìm kiếm bài hát"
                    name="keyword"
                )
            a(
                href=`${prefixAdmin}/songs/create`
                class="btn-add"
            )
                i(class="fa fa-plus")
                |  Thêm mới
        // TABLE
        table(class="table")
            thead
                tr
                    th STT
                    th Hình ảnh
                    th Bài hát
                    th Ca sĩ
                    th Mô tả
                    th Trạng thái
                    th Phát hành
                    th Thao tác

            tbody
                each item, index in songs
                    tr
                        td #{index + 1}
                        td  
                            img(
                                src=item.avatar
                                width="60"
                            )
                        td #{item.nameSong}
                        td #{item.nameSinger}
                        td !{item.description}
                        td 
                            if(item.status === "active")
                                button(
                                    class="status active"
                                    id-status=item._id
                                    status = item.status
                                ) Active
                            else
                                button(
                                    status = item.status
                                    class="status inactive"
                                    id-status=item._id
                                ) Inactive
                        td 
                            +date(item.releaseDate)
                        td(class="action-btns")
                            a(
                                href=`${prefixAdmin}/songs/edit/${item._id}`
                                class="btn-edit" 
                                data-id=item._id 
                                title="Sửa"
                            )
                                i(class="fa fa-pen")
                            button(
                                btn-delete
                                class="btn-delete" 
                                data-id=item._id 
                                title="Xóa"
                            )
                                i(class="fa fa-trash")
    .pagination-wrapper
        +pagination

    form(
        action = `${prefixAdmin}/songs`
        id="form-get-path"
    )
    form(
        action = `${prefixAdmin}/songs/delete`
        method="POST"
        id="form-delete"
    )