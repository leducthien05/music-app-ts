extends ../../layout/default
include ../../mixin/pagination.pug

block content
    div(class="dashboard")

        // STAT CARDS
        div(class="stats")
            div(class="card")
                p Tổng bài hát
                h2 1,248
                span(class="up") ↑ 12 bài tuần này

            div(class="card")
                p Lượt nghe hôm nay
                h2 8,462
                span(class="up") ↑ 5.2%

            div(class="card")
                p Người dùng
                h2 3,891
                span(class="up") ↑ 24

            div(class="card")
                p Yêu thích
                h2 15,703
                span(class="down") ↓ 1.1%

        // FILTER
        div(class="tabs")
            span(class="active") Tất cả
            span Đã đăng
            span Bản nháp
            span Ẩn
        

        // SEARCH
        div(class="search-bar")
            form(
                method="GET"
                form-search
                
            )
                input(
                    type="text", 
                    placeholder="Tìm kiếm thể loại"
                    name="keyword"
                )
            a(
                href="/admin/songs/create"
                class="btn-add"
            )
                i(class="fa fa-plus")
                |  Thêm mới
        // TABLE
        table(class="table")
            thead
                tr
                    th STT
                    th Hình ảnh
                    th Bài hát
                    th Ca sĩ
                    th Mô tả
                    th Trạng thái
                    th Thời gian
                    th Thao tác

            tbody
                each item, index in songs
                    tr
                        td #{index + 1}
                        td  
                            img(
                                src=item.avatar
                                width="60"
                            )
                        td #{item.nameSong}
                        td #{item.nameSinger}
                        td !{item.description}
                        td 
                            if(item.status === "active")
                                span(class="status active") Active
                            else
                                span(class="status inactive") Inactive
                        td #{item.createAt}
                        td(class="action-btns")
                            a(
                                href=`${prefixAdmin}/songs/edit/${item._id}`
                                class="btn-edit" 
                                data-id=item._id 
                                title="Sửa"
                            )
                                i(class="fa fa-pen")
                            button(
                                class="btn-delete" 
                                data-id=item._id 
                                title="Xóa"
                            )
                                i(class="fa fa-trash")
    .pagination-wrapper
        +pagination