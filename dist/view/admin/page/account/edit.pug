extends ../../layout/default.pug

block content   
    if(roleAccount.permission.includes("accounts_edit"))
        div(class="dashboard-form")
            form(
                class="form-add-song" 
                method="POST" 
                action=`${prefixAdmin}/accounts/edit/${account._id}?_method=PATCH` 
                enctype="multipart/form-data"
            )
                
                //- // ===== THÔNG TIN CƠ BẢN =====
                .card
                    h3(class="card-title") 🎵 Thông tin cơ bản

                    .form-grid
                        .form-group
                            label Họ và Tên *
                            input(
                                type="text" 
                                name="fullName" 
                                value = account.fullName
                                placeholder="VD: Lê Văn A"
                            )
                        .form-group
                            label Email *
                            input(
                                type="text" 
                                name="email" 
                                value = account.email
                                placeholder="VD: exam@gmail.com"
                            )
                        .form-group
                            label Mật khẩu *
                            input(
                                type="password" 
                                name="password" 
                            )
                        .form-group
                            label Quyền
                            select(name="role_id")
                                option(value="" selected = true) Quyền
                                each item in role 
                                    option(
                                        value=item._id 
                                        selected = (item.id == account.role_id) ? true : false
                                    ) #{item.title}
                // ===== MEDIA =====
                .card
                    h3.card-title 🖼️ Hình ảnh 

                    .form-grid
                        .upload-box
                            label Hình ảnh đại diện *
                            input(
                                type="file" 
                                name="avatar"
                            )
                            img(
                                src = account.avatar
                                width="100"
                            )

                // ===== CÀI ĐẶT =====
                .card
                    h3.card-title ⚙️ Cài đặt xuất bản

                    .form-grid
                        .form-group
                            label Trạng thái *
                            .radio-group
                                label
                                    input(
                                        type="radio" 
                                        name="status" 
                                        value="active" 
                                        checked = (account.status == "active" ? true : false)
                                    )
                                    |  Hoạt động
                                label
                                    input(
                                        type="radio"
                                        name="status"
                                        value="inactive"
                                        checked = (account.status == "inactive" ? true : false)
                                    )
                                    |  Ngừng hoạt động
                //- // ===== ACTION =====
                .form-actions
                    button(
                        class="btn-submit"
                        type="submit"
                    ) + Thêm tài khoản