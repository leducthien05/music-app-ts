extends ../../layout/default

block content    
    if(roleAccount.permission.includes("topics_edit"))
        div(class="dashboard-form")
            form(
                class="form-add-song" 
                method="POST" 
                action=`${prefixAdmin}/topics/edit/${topic._id}?_method=PATCH`
                enctype="multipart/form-data"
            )
                
                // ===== THÔNG TIN CƠ BẢN =====
                .card
                    h3(class="card-title") Thông tin cơ bản

                    .form-grid
                        .form-group
                            label Tên thể loại *
                            input(
                                type="text" 
                                name="title" 
                                value = topic.title
                                placeholder="VD: POP"
                            )
                    .form-group
                        label Mô tả *
                        textarea(
                            class="tinymce"
                            name="description" 
                            placeholder="Mô tả ngắn về bài hát..." 
                            rows="4"
                        ) !{topic.description}
                // ===== MEDIA =====
                .card
                    h3.card-title 🖼️ Hình ảnh 

                    .form-grid
                        .upload-box
                            label Hình ảnh bìa *
                            input(
                                type="file" 
                                name="avatar"
                            )
                            img(
                                src=topic.avatar
                            )

                // ===== CÀI ĐẶT =====
                .card
                    h3.card-title ⚙️ Cài đặt 

                    .form-grid
                        .form-group
                            label Trạng thái *
                            .radio-group
                                label
                                    input(
                                        type="radio" 
                                        name="status" 
                                        value="active" 
                                        checked = (topic.status == "active" ? true : false)
                                    )
                                    |  Hoạt động
                                label
                                    input(
                                        type="radio"
                                        name="status"
                                        value="inactive"
                                        checked = (topic.status == "inactive" ? true : false)
                                    )
                                    |  Ẩn

                // ===== ACTION =====
                .form-actions
                    button(
                        class="btn-reset" 
                        type="reset"
                    ) Làm mới
                    button(
                        class="btn-submit"
                        type="submit"
                    ) + Cập nhật thể loại