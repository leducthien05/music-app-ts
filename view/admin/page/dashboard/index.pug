extends ../../layout/default

block content
    div(class="dashboard")

        // STAT CARDS
        div(class="stats")
            div(class="card")
                p Tổng bài hát
                h2 1,248
                span(class="up") ↑ 12 bài tuần này

            div(class="card")
                p Lượt nghe hôm nay
                h2 8,462
                span(class="up") ↑ 5.2%

            div(class="card")
                p Người dùng
                h2 3,891
                span(class="up") ↑ 24

            div(class="card")
                p Yêu thích
                h2 15,703
                span(class="down") ↓ 1.1%

        // FILTER
        div(class="tabs")
            span(class="active") Tất cả
            span Đã đăng
            span Bản nháp
            span Ẩn

        // SEARCH
        div(class="search-bar")
            input(type="text", placeholder="Tìm kiếm bài hát, nghệ sĩ...")
            button Thể loại

        // TABLE
        table(class="table")
            thead
                tr
                th #
                th Bài hát
                th Thể loại
                th Lượt nghe
                th Yêu thích
                th Trạng thái
                th Thời gian
                th Thao tác

            tbody
                tr
                td 1
                td Chill Vibes - Sơn Tùng
                td V-Pop
                td 4
                td 1
                td 
                    span(class="status active") Đã đăng
                td 7:05
                td
                    i(class="fa fa-pen")
                    i(class="fa fa-trash")