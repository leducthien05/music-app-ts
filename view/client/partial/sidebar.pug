    // 🔥 AUTH ACTIONS
    .auth-actions
        if user
            .user-info
                span Xin chào, #{user.name}
            a(
                class="btn-logout"
                href="/users/logout"
            ) Đăng xuất
        else
            a(
                class="btn-login"
                href="/users/login") Đăng nhập
            a(
                class="btn-register"
                href="/users/register") Đăng ký